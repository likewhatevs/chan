/target
# cargo-generate-rpm writes to <cwd>/target/, so a local rpm
# build from inside crates/chan/ creates a per-package target
# dir that the workspace-root /target rule doesn't catch.
**/target/
Cargo.lock

# Editor swap / backup files
*.swp
*.swo
*.swn
*~
.DS_Store

# Frontend build artifacts
node_modules/
web/dist/
web/pkg/
.svelte-kit/
.vite/

# Embedding model bundle. Populated by `make models` for release
# builds; large (~130 MB) and a moving target as upstream model
# weights revise, so we keep it out of git and rely on fetch-models
# to seed it before linking. .gitkeep ensures the directory itself
# stays in the tree so rust-embed has a target.
crates/chan-server/resources/models/*
!crates/chan-server/resources/models/.gitkeep
