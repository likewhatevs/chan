/target
# cargo-generate-rpm writes to <cwd>/target/, so a local rpm
# build from inside crates/chan/ creates a per-package target
# dir that the workspace-root /target rule doesn't catch.
**/target/

# Editor swap / backup files
*.swp
*.swo
*.swn
*~
.DS_Store

# Frontend build artifacts. The ./web npm-workspaces root builds its members
# to the FROZEN rust-embed input paths (X-2): workspace-app -> web/dist,
# launcher -> web-launcher/dist, profile -> gateway/crates/identity/web/dist.
# Those output dirs stay where the rust-embed derives read them even though the
# source now lives under web/packages/.
node_modules/
web/dist/
web/.chan-build-stamp
web/pkg/
web-launcher/dist/
web-launcher/.chan-build-stamp
.svelte-kit/
.vite/

# Embedding model bundle. Populated by `make models` for release
# builds (~80 MB tar.zst); a moving target as upstream weights
# revise, so we keep it out of git and rely on fetch-models to
# write it before linking. build.rs creates an empty stub on a
# fresh clone so `cargo build` doesn't fail before the first
# `make models`. The .gitkeep under resources/ keeps the dir in
# the tree so build.rs and include_bytes! resolve cleanly.
crates/chan-server/resources/models.tar.zst
crates/chan-server/resources/models/

# Claude Code local state (machine-local, not shared)
.claude/settings.local.json
.claude/worktrees/

# Team Work session scaffolding (local multi-agent sessions; the dir
# name is chosen at spawn time, so add new ones here as needed)
/new-team-1/
/web-team/

# Local scratch / working area for in-flight design notes and agent
# plans. Not shipped; design that needs to persist goes under docs/.
/dev/

# Local multi-agent Team Work scratch dirs (journals, tasks, bootstrap).
# Coordination that needs to persist goes under docs/journals/phase-N/.
/new-team-*/

# In-workspace drafts dir chan creates when the repo itself is served
# as a chan workspace (Cmd+N drafts land in .Drafts/). Machine-local
# serve artifact, not source.
/.Drafts/
