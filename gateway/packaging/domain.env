# /etc/chan-gateway/domain.env
#
# Shared domain config for the gateway. Loaded by the identity and
# workspace-proxy systemd units (EnvironmentFile=-...), so the public
# hostnames live in ONE place instead of being repeated per service.
# Generated by scripts/configure.sh; this file in the repo is the
# reference template.
#
# CHAN_DOMAIN is the base domain. Both services derive their hosts
# from it and therefore cannot drift (the workspace-gate JWT `aud` is
# the inbound host, so the two MUST agree):
#
#   id.<CHAN_DOMAIN>           identity-service       (id.chan.app)
#   workspace.<CHAN_DOMAIN>    workspace-proxy apex   (workspace.chan.app)
#   *.workspace.<CHAN_DOMAIN>  per-user tenant host   (alice.workspace.chan.app)
#
# PUBLIC_SCHEME is the scheme for the URLs the services build (https
# in prod, http for a local/dev stack).
#
# Changing the domain here is necessary but not sufficient: it must be
# matched by DNS, the wildcard TLS cert, and the reverse proxy's
# server_name. Restart both services after editing:
#   systemctl restart chan-gateway-identity chan-gateway-workspace-proxy

CHAN_DOMAIN=chan.app
PUBLIC_SCHEME=https
