# /etc/chan-gateway/devserver-proxy.env
#
# Edit this file then `systemctl restart chan-gateway-devserver-proxy`.
# Permissions are 0640 root:chan-gateway-devserver-proxy; do not relax.
#
# DEVSERVER_TUNNEL_ORIGIN, DEVSERVER_PROXY_BASE_URL, and DASHBOARD_URL
# are required in the shared /etc/chan-gateway/domain.env.

BIND_ADDR=127.0.0.1:7002
TUNNEL_BIND_ADDR=127.0.0.1:7100

# identity-service base URL + the bearer presented on
# /internal/v1/tokens/validate. The token must equal identity's
# IDENTITY_INTERNAL_TOKEN. Generate with: openssl rand -hex 32
IDENTITY_URL=http://127.0.0.1:7004
IDENTITY_INTERNAL_TOKEN=

# One or two semicolon-separated Ed25519 public keys for short-lived browser
# entry artifacts. During rotation carry current;old for at least 35 seconds.
DEVSERVER_ENTRY_VERIFYING_KEYS=

# Exact public identity origin allowed to POST entry credentials.
IDENTITY_PUBLIC_ORIGIN=https://id.chan.app

# Singleton controller h2c listener, dedicated shared bearer, and this
# provisioned node's stable id. DEVSERVER_PROXY_BASE_URL is supplied by
# the shared domain environment named above.
DEVSERVER_CONTROL_URL=http://127.0.0.1:7101
DEVSERVER_PROXY_TOKEN=
DEVSERVER_PROXY_ID=p1

# RUST_LOG=info,devserver_proxy=debug
