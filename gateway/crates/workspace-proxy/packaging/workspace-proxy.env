# /etc/chan-gateway/workspace-proxy.env
#
# Edit this file then `systemctl restart chan-gateway-workspace-proxy`.
# Permissions are 0640 root:chan-gateway; do not relax.
#
# Public hostnames come from the shared /etc/chan-gateway/domain.env
# (CHAN_DOMAIN + PUBLIC_SCHEME), loaded first by the systemd unit.
# workspace-proxy holds no database; it is a stateless reverse proxy.

BIND_ADDR=127.0.0.1:7002
TUNNEL_BIND_ADDR=127.0.0.1:7100

# identity-service base URL + the bearer presented on
# /internal/v1/tokens/validate. The token must equal identity's
# IDENTITY_INTERNAL_TOKEN. Generate with: openssl rand -hex 32
IDENTITY_URL=http://127.0.0.1:7000
IDENTITY_INTERNAL_TOKEN=

# HS256 secret for the workspace-gate handoff. MUST be the same value
# as identity's WORKSPACE_GATE_SECRET. Generate with:
#   openssl rand -hex 32
WORKSPACE_GATE_SECRET=

# Bearer for the /admin/v1/* tree (tunnel ps / kill / watch). Must
# match the operator's chan-gateway-admin CHAN_ADMIN_TOKEN. Leave
# empty to disable the admin tree (every /admin/v1/* call returns 401).
WORKSPACE_ADMIN_TOKEN=

# Optional: cap concurrent workspace registrations per user
# (0 = unlimited).
MAX_WORKSPACES_PER_USER=0

# RUST_LOG=info,workspace_proxy=debug
