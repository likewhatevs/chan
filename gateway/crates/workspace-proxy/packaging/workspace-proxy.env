# /etc/chan-gateway/workspace-proxy.env
#
# Edit this file then `systemctl restart chan-gateway-workspace-proxy`.
# Permissions are 0640 root:chan-gateway; do not relax.

BIND_ADDR=127.0.0.1:7002
DATABASE_URL=postgres://chan:chan@127.0.0.1/chan_gateway

COOKIE_SECURE=true

# Where anonymous visitors are sent to sign in.
IDENTITY_BASE_URL=https://id.chan.app

PROFILE_SERVICE_URL=http://127.0.0.1:7001
PROFILE_AUTH_TOKEN=

# Bearer for the /admin/v1/* tree (tunnel ps / kill / watch).
# Distinct from PROFILE_AUTH_TOKEN; must match the CHAN_ADMIN_TOKEN
# the operator's chan-gateway-admin uses. Leave empty to disable
# the admin tree (every /admin/v1/* call returns 401).
WORKSPACE_ADMIN_TOKEN=

# Shared bearer presented by chan-tunneld on
# /internal/v1/registrations. Generate with:
#   openssl rand -hex 32
# tunneld's REGISTRY_TOKEN must match.
REGISTRY_TOKEN=

# Optional: drop tunnel registrations that haven't refreshed within
# this many seconds. tunneld is expected to re-register well below
# the limit. Default 90.
# REGISTRY_TTL_SECONDS=90

# RUST_LOG=info,workspace_proxy=debug
