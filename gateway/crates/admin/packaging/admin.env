# chan-gateway-admin reads these on every invocation. Override on
# the command line with the scoped URL/token flags, or
# `source` this file from a shell profile. packaging/gateway/scripts/configure.sh
# regenerates this file with matching, distinct tokens.
#
# CHAN_ADMIN_PROFILE_URL    HTTP URL of the internal profile-service.
# CHAN_ADMIN_WORKSPACE_URL  HTTP URL of devserver-control. Used by the
#                           `tunnel` and `proxy` subcommands.
# CHAN_ADMIN_PROFILE_TOKEN  Bearer for profile-service.
# CHAN_ADMIN_IDENTITY_TOKEN Bearer for identity-service.
# CHAN_ADMIN_OPERATOR_TOKEN Bearer for devserver-control operator routes.
# These values are deliberately distinct; no shared-token fallback is valid.
#
# Defaults are loopback for a single-host deploy. Point them at your
# service addresses (e.g. container DNS names) for a multi-host setup.

CHAN_ADMIN_PROFILE_URL=http://127.0.0.1:7001
CHAN_ADMIN_WORKSPACE_URL=http://127.0.0.1:7003
CHAN_ADMIN_PROFILE_TOKEN=
CHAN_ADMIN_IDENTITY_TOKEN=
CHAN_ADMIN_OPERATOR_TOKEN=
