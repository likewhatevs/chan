# chan-gateway-admin reads these on every invocation. Override on
# the command line with --profile-url / --drive-url / --token, or
# `source` this file from a shell profile.
#
# CHAN_ADMIN_PROFILE_URL  HTTP URL of the internal profile-service.
#                         Inside the chan-svc sdme zone this is
#                         http://chan-profile:7001 .
# CHAN_ADMIN_DRIVE_URL    HTTP URL of drive-proxy. Used by the
#                         `tunnel` subcommands. http://chan-drive:7002
#                         inside chan-svc.
# CHAN_ADMIN_TOKEN        Single bearer used for both services.
#                         Must match profile-service's
#                         PROFILE_ADMIN_TOKEN AND drive-proxy's
#                         DRIVE_ADMIN_TOKEN. Generated by
#                         secrets-init.sh and stored at
#                         /var/lib/chan/secrets/admin.env in prod.

CHAN_ADMIN_PROFILE_URL=http://chan-profile:7001
CHAN_ADMIN_DRIVE_URL=http://chan-drive:7002
CHAN_ADMIN_TOKEN=
