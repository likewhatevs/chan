# /etc/chan-gateway/migrate.env
#
# Read only by chan-gateway-migrate. The URL carries the database owner
# credential and must never appear in identity.env or profile.env.

DATABASE_URL=postgres://chan:chan@127.0.0.1/chan_gateway
IDENTITY_DATABASE_PASSWORD=REPLACE
PROFILE_DATABASE_PASSWORD=REPLACE
CHAN_GATEWAY_MIGRATIONS=only
EXPECTED_SQLX_MIGRATION=15
DATABASE_ROLE_POLICY_VERSION=1
