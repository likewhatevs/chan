# /etc/chan-gateway/identity.env
#
# Edit this file then `systemctl restart chan-gateway-identity`.
# Permissions are 0640 root:chan-gateway; do not relax.

BIND_ADDR=127.0.0.1:7000

# Public hostnames come from the shared /etc/chan-gateway/domain.env
# (CHAN_DOMAIN + PUBLIC_SCHEME). BASE_URL defaults to
# https://id.<CHAN_DOMAIN>; set it here only if the public origin
# differs (e.g. a non-default port). It must match each OAuth app's
# Authorization callback URL (BASE_URL + /auth/<provider>/callback).
# BASE_URL=https://id.chan.app

DATABASE_URL=postgres://chan:chan@127.0.0.1/chan_gateway

# True in production behind TLS-terminating reverse proxy.
COOKIE_SECURE=true

PROFILE_SERVICE_URL=http://127.0.0.1:7001
PROFILE_AUTH_TOKEN=

# Bearer workspace-proxy presents on /internal/v1/tokens/validate.
# Required and distinct from PROFILE_AUTH_TOKEN; must equal
# workspace-proxy's IDENTITY_INTERNAL_TOKEN. openssl rand -hex 32
IDENTITY_INTERNAL_TOKEN=

# HS256 secret for the workspace-gate handoff. MUST equal
# workspace-proxy's WORKSPACE_GATE_SECRET. openssl rand -hex 32
WORKSPACE_GATE_SECRET=

# workspace-proxy admin client, used on PAT revoke / account delete /
# dashboard reads. WORKSPACE_ADMIN_URL is required when the token is
# set; the token must match workspace-proxy's WORKSPACE_ADMIN_TOKEN.
WORKSPACE_ADMIN_URL=http://127.0.0.1:7002
WORKSPACE_ADMIN_TOKEN=

# Configure at least ONE of the providers below (more is fine).
# identity-service refuses to start if none are set.

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client IDs, Web application type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitLab: https://gitlab.com/-/user_settings/applications
# (Scope: read_user)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# RUST_LOG=info,identity=debug
