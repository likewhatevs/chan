# /etc/chan-gateway/identity.env
#
# Edit this file then `systemctl restart chan-gateway-identity`.
# Permissions are 0640 root:chan-gateway-identity; do not relax.

BIND_ADDR=127.0.0.1:7000
# Proxy-authenticated token validation is never served by the public listener.
INTERNAL_BIND_ADDR=127.0.0.1:7004
# BASE_URL, DEVSERVER_PROXY_ORIGIN, and DEVSERVER_TUNNEL_ORIGIN are
# required in the shared /etc/chan-gateway/domain.env.

# Non-DDL application role. Database-owner credentials belong only in
# /etc/chan-gateway/migrate.env.
DATABASE_URL=postgres://chan_gateway_identity:REPLACE@127.0.0.1/chan_gateway
CHAN_GATEWAY_MIGRATIONS=external
EXPECTED_SQLX_MIGRATION=15
DATABASE_ROLE_POLICY_VERSION=1

# True in production behind TLS-terminating reverse proxy.
COOKIE_SECURE=true

PROFILE_SERVICE_URL=http://127.0.0.1:7001
PROFILE_AUTH_TOKEN=

# Bearer devserver-proxy presents on /internal/v1/tokens/validate.
# Required and distinct from PROFILE_AUTH_TOKEN; must equal
# devserver-proxy's IDENTITY_INTERNAL_TOKEN. openssl rand -hex 32
IDENTITY_INTERNAL_TOKEN=

# Ed25519 admission signing key as canonical unpadded base64url of the raw
# 32-byte secret key. Only identity holds this key; devserver-control holds
# the corresponding DEVSERVER_ADMISSION_VERIFYING_KEYS ring.
DEVSERVER_ADMISSION_SIGNING_KEY=
# The matching one-or-two-key ring is also required locally to verify
# browser-bound admission artifacts; it is not secret.
DEVSERVER_ADMISSION_VERIFYING_KEYS=

# Private Ed25519 seed for short-lived browser entry artifacts. Proxies receive
# only the corresponding public DEVSERVER_ENTRY_VERIFYING_KEYS ring.
DEVSERVER_ENTRY_SIGNING_KEY=

# Operator bearer for identity's own /admin/v1/tokens route.
IDENTITY_ADMIN_TOKEN=

# devserver-control admin client, used on PAT revoke / account delete /
# dashboard reads. DEVSERVER_ADMIN_URL is required when the token is
# set; the singular bearer must match the current value in
# devserver-control's DEVSERVER_IDENTITY_ADMIN_TOKENS ring.
DEVSERVER_ADMIN_URL=http://127.0.0.1:7003
DEVSERVER_IDENTITY_ADMIN_TOKEN=

# Configure at least ONE of the providers below (more is fine).
# identity-service refuses to start if none are set.

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client IDs, Web application type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitLab: https://gitlab.com/-/user_settings/applications
# (Scope: read_user)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# RUST_LOG=info,identity=debug
