# /etc/chan-gateway/profile.env
#
# Edit this file then `systemctl restart chan-gateway-profile`.
# Permissions are 0640 root:chan-gateway; do not relax.

BIND_ADDR=127.0.0.1:7001
DATABASE_URL=postgres://chan:chan@127.0.0.1/chan_gateway

# Shared bearer token used by sibling gateway services
# (identity, devserver-proxy) to call profile-service. Generate with:
#   openssl rand -hex 32
PROFILE_AUTH_TOKEN=

# Admin bearer for the /v1/admin/* tree. Must match the operator's
# chan-gateway-admin CHAN_ADMIN_TOKEN. openssl rand -hex 32
PROFILE_ADMIN_TOKEN=

# devserver-proxy admin client: on admin block, profile fans out to
# devserver-proxy to evict the user's live tunnels (best-effort), and
# the registry sweeper reads the live-tunnel snapshot from it. Set
# both to enable; the token must match devserver-proxy's
# DEVSERVER_ADMIN_TOKEN. Leave unset to skip the fan-out (the sweeper
# then does not run).
DEVSERVER_ADMIN_URL=http://127.0.0.1:7002
DEVSERVER_ADMIN_TOKEN=

# Devserver registry sweeper: rows offline longer than this many
# minutes are deleted (their grants cascade away; the devserver
# reappears unlabeled on its next dial). Unset or empty = 15.
# 0 disables the sweeper. Requires the devserver-proxy admin client
# above for the live-tunnel snapshot.
# DEVSERVER_RETENTION_MINUTES=15

# RUST_LOG=info,profile=debug
