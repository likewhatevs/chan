# /etc/chan-gateway/profile.env
#
# Edit this file then `systemctl restart chan-gateway-profile`.
# Permissions are 0640 root:chan-gateway-profile; do not relax.

BIND_ADDR=127.0.0.1:7001
# Non-DDL application role. Database-owner credentials belong only in
# /etc/chan-gateway/migrate.env.
DATABASE_URL=postgres://chan_gateway_profile:REPLACE@127.0.0.1/chan_gateway
CHAN_GATEWAY_MIGRATIONS=external
EXPECTED_SQLX_MIGRATION=15
DATABASE_ROLE_POLICY_VERSION=1

# Shared bearer token used by sibling gateway services
# (identity, devserver-proxy) to call profile-service. Generate with:
#   openssl rand -hex 32
PROFILE_AUTH_TOKEN=

# Admin bearer for the /v1/admin/* tree. Must match the operator's
# CHAN_ADMIN_PROFILE_TOKEN. openssl rand -hex 32
PROFILE_ADMIN_TOKEN=

# devserver-control admin client: profile's durable revocation worker cuts
# tunnels and browser sessions after every denial mutation, and the registry
# sweeper reads the aggregate live-tunnel snapshot. The bearer must match one
# current value in devserver-control's DEVSERVER_PROFILE_ADMIN_TOKENS ring.
DEVSERVER_ADMIN_URL=http://127.0.0.1:7003
DEVSERVER_PROFILE_ADMIN_TOKEN=

# Devserver registry sweeper: rows offline longer than this many
# minutes are deleted (their grants cascade away; the devserver
# reappears unlabeled on its next dial). Unset or empty = 15.
# 0 disables the sweeper. Requires the devserver-control admin client
# above for the aggregate live-tunnel snapshot.
# DEVSERVER_RETENTION_MINUTES=15

# RUST_LOG=info,profile=debug
