# /etc/chan-gateway/devserver-control.env
#
# Edit this file then `systemctl restart chan-gateway-devserver-control`.
# Permissions are 0640 root:chan-gateway-devserver-control; do not relax.

BIND_ADDR=127.0.0.1:7003
PROXY_BIND_ADDR=127.0.0.1:7101

# Scope-specific verifier rings for /admin/v1/*. Each value is
# current[;next] during rotation (one or two distinct tokens). Never reuse a
# token between scopes. Callers receive only their matching singular bearer.
DEVSERVER_OPERATOR_ADMIN_TOKENS=
DEVSERVER_IDENTITY_ADMIN_TOKENS=
DEVSERVER_PROFILE_ADMIN_TOKENS=

# Provisioned proxy identities for /v1/proxies/connect. Format:
# proxy_id=token;proxy_id=next_token;other_id=token. Each proxy id may have at
# most two tokens during rotation. Keep these distinct from the admin token.
DEVSERVER_PROXY_CREDENTIALS=

# One or two distinct Ed25519 admission public keys as canonical unpadded
# base64url, current[;next]. identity holds only the active signing key.
DEVSERVER_ADMISSION_VERIFYING_KEYS=

# Canonical origin template with exactly one {proxy_id} placeholder,
# for example https://{proxy_id}.usr.chan.app. Each proxy's
# DEVSERVER_PROXY_BASE_URL must match its expansion exactly.
# configure.sh writes it here; it may also live in the shared
# /etc/chan-gateway/domain.env.
# DEVSERVER_PROXY_BASE_URL_TEMPLATE=

# Fleet-wide cap over active and pending distinct devserver ids per
# user. 0 disables the cap.
MAX_DEVSERVERS_PER_USER=100

# RUST_LOG=info,devserver_control=debug
