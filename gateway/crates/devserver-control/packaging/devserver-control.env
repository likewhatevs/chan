# /etc/chan-gateway/devserver-control.env
#
# Edit this file then `systemctl restart chan-gateway-devserver-control`.
# Permissions are 0640 root:chan-gateway; do not relax.

BIND_ADDR=127.0.0.1:7003
PROXY_BIND_ADDR=127.0.0.1:7101

# Bearer for the /admin/v1/* aggregate tree. identity, profile, and
# chan-gateway-admin present it as their DEVSERVER_ADMIN_TOKEN /
# CHAN_ADMIN_TOKEN. Generate with: openssl rand -hex 32
DEVSERVER_ADMIN_TOKEN=

# Bearer each proxy presents on /v1/proxies/connect. Must equal every
# proxy's DEVSERVER_PROXY_TOKEN and stay distinct from
# DEVSERVER_ADMIN_TOKEN. Generate with: openssl rand -hex 32
DEVSERVER_PROXY_TOKEN=

# Canonical origin template with exactly one {proxy_id} placeholder,
# for example https://{proxy_id}.usr.chan.app. Each proxy's
# DEVSERVER_PROXY_BASE_URL must match its expansion exactly.
# configure.sh writes it here; it may also live in the shared
# /etc/chan-gateway/domain.env.
# DEVSERVER_PROXY_BASE_URL_TEMPLATE=

# Fleet-wide cap over active and pending distinct devserver ids per
# user. 0 disables the cap.
MAX_DEVSERVERS_PER_USER=100

# RUST_LOG=info,devserver_control=debug
