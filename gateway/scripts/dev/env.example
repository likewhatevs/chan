# Local dev env. Copy to scripts/dev/.env and fill in.
#
# Required: one OAuth provider. GitHub is the easiest because
# their OAuth app accepts a plain http://localhost-shaped callback.
# Generate a dev OAuth app at:
#     https://github.com/settings/developers
# and use:
#     Authorization callback URL = http://id.localtest.me:7000/auth/github/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: Google + GitLab. Same callback URL pattern, point at
# id.localtest.me:7000/auth/<provider>/callback.
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GITLAB_CLIENT_ID=
#GITLAB_CLIENT_SECRET=

# Postgres connection string. Leave defaulted unless you already
# have something at 127.0.0.1:5432 that conflicts.
DATABASE_URL=postgres://chan:chan@127.0.0.1/chan_gateway
