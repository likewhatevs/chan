{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the singleton main launcher plus any additional main-N launchers spawned via File > New Window (fullstack-83).",
  "windows": ["main", "main-*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "deep-link:default",
    "opener:default",
    "opener:allow-open-url",
    "process:default",
    "process:allow-restart",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
