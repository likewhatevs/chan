{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the singleton main launcher; the main-* glob keeps any additional launcher-class window on the same permission set.",
  "windows": ["main", "main-*"],
  "permissions": [
    "main-window",
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "deep-link:default",
    "opener:default",
    "opener:allow-open-url",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
