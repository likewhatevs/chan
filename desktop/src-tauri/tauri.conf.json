{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chan",
  "version": "0.10.0",
  "identifier": "com.chanwriter.desktop",
  "mainBinaryName": "chan-desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Chan Desktop",
        "width": 960,
        "height": 600,
        "minWidth": 720,
        "minHeight": 400,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["chan"]
      }
    },
    "updater": {
      "endpoints": [
        "https://chan.app/dl/desktop/{{target}}/{{current_version}}/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2MDVGRjI1MDdGOEM5RDIKUldUU3lmZ0hKZjhGZHJvYi9FLzJqQkhkRHdhMHVKUW5MeGg0OUFySnJkbUtxeU5od0l5MFh0MXAK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/chan"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Chan Desktop markdown editor",
    "longDescription": "Chan Desktop — markdown editor with local drives.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
