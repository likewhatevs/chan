    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-src https://www.youtube-nocookie.com https://www.google.com"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["chan"]
      }
    },
    "updater": {
      "endpoints": [
        "https://chan.app/dl/desktop/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzQjY3RDk4MDI2QjIwMkQKUldRdElHc0NtSDIyRS9haDU1TGNjakFMZEcxcGVjT0p2bnpFMUN3Vm8vb25obldTZ1lLWXN5OUkK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
