{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChanDesktop",
  "version": "0.1.0",
  "identifier": "com.chanwriter.desktop",
  "mainBinaryName": "chan-desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Chan Desktop",
        "width": 960,
        "height": 600,
        "minWidth": 720,
        "minHeight": 400,
        "resizable": true,
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "Chan Desktop — Settings",
        "width": 560,
        "height": 320,
        "resizable": false,
        "visible": false,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Chan Desktop markdown editor",
    "longDescription": "Chan Desktop — markdown editor with local drives.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
