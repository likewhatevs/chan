{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for main and settings windows.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-url",
    "process:default",
    "process:allow-restart",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
