{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for main and settings windows.",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-ask",
    "opener:default",
    "opener:allow-reveal-item-in-dir"
  ]
}
