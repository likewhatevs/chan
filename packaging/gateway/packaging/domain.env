# /etc/chan-gateway/domain.env
#
# Shared domain config for the gateway. Loaded by the identity and
# devserver-proxy systemd units (EnvironmentFile=-...), so the public
# hostnames live in ONE place instead of being repeated per service.
# Generated by packaging/gateway/scripts/configure.sh; this file in the repo is the
# reference template.
#
# All public origins are explicit. The examples below use one deployment;
# replace them with origins from any domain. DNS, certificates, and reverse
# proxy routing must match. Restart both services after editing:
#   systemctl restart chan-gateway-identity chan-gateway-devserver-proxy

BASE_URL=https://gw.chan.app
DEVSERVER_PROXY_ORIGIN=https://usr.chan.app
DEVSERVER_TUNNEL_ORIGIN=https://usr.chan.app
DEVSERVER_PROXY_BASE_URL=https://p1.usr.chan.app
DASHBOARD_URL=https://gw.chan.app/workspaces
