#!/usr/bin/env bash
# Pre-push gate: fmt + clippy + test + no-default-features build.
# Mirrors CI warning gates and runs the drive-heavy test suite serially
# to avoid macOS per-process descriptor pressure. Install with
# ./scripts/install-hooks.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "==> cargo fmt --check"
cargo fmt --check

echo "==> cargo test --all-targets -- --test-threads=1"
cargo test --all-targets -- --test-threads=1

echo "==> cargo clippy --all-targets -- -D warnings"
cargo clippy --all-targets -- -D warnings

# The mcp feature pulls rmcp + schemars; the default cargo invocation
# above doesn't enable it, which is how the v0.7.0 mcp.rs regression
# reached main. Exercise the feature-on path here too.
echo "==> cargo clippy -p chan-llm --all-targets --features mcp -- -D warnings"
cargo clippy -p chan-llm --all-targets --features mcp -- -D warnings

echo "==> cargo test -p chan-llm --all-targets --features mcp"
cargo test -p chan-llm --all-targets --features mcp

echo "==> RUSTFLAGS='-D warnings' cargo build -p chan-drive --no-default-features"
RUSTFLAGS="-D warnings" cargo build -p chan-drive --no-default-features
